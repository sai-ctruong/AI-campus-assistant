# Sao chép thành .env và điền giá trị thật. File .env bị gitignore.
GEMINI_API_KEY=your_gemini_api_key_here

# Local: mặc định đủ dùng. Khi deploy, thêm domain frontend (phân tách bằng dấu phẩy):
# CORS_ORIGINS=https://ai-campus.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Khi deploy có volume bền, trỏ dữ liệu vào đó:
# DATA_DIR=/data
# CHROMA_PERSIST_DIR=/data/chroma
# UPLOAD_DIR=/data/uploads
